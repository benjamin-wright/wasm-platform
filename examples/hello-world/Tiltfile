def hello_world(namespace, resource_deps=[]):
    # Tell Tilt the Application CRD carries an OCI image reference at
    # spec.module.  Tilt will rewrite that field to the in-cluster registry
    # address (port 5000) with a content-based tag before applying the CR,
    # exactly as it does for Deployment images.  pod_readiness='ignore'
    # because the Application itself spawns no pods.
    k8s_kind('Application',
             image_json_path = '{.spec.functions[*].module}',
             pod_readiness = 'ignore')

    # Build the WASM module and push it to the local registry.  Tilt passes
    # the content-addressed reference as $EXPECTED_REF so every content
    # change produces a new tag and triggers operator reconciliation.
    custom_build(
        'hello-world',
        command = (
            'cargo build --manifest-path examples/hello-world/Cargo.toml' +
            ' --target wasm32-wasip2 --release &&' +
            ' oras push $EXPECTED_REF' +
            ' target/wasm32-wasip2/release/hello_world.wasm' +
            ' --artifact-type application/vnd.wasm.content.layer.v1+wasm' +
            ' --plain-http'
        ),
        deps = [
            'examples/hello-world/src',
            'framework/runtime.wit',
        ],
        skips_local_docker = True,
    )

    k8s_yaml('examples/hello-world/k8s/application.yaml')

    k8s_resource(
        'hello-world',
        resource_deps = ['module-cache', 'wp-operator'] + resource_deps,
        labels = ['example'],
    )
