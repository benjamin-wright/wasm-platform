load('ext://helm_resource', 'helm_resource')

IMAGE_REF = 'wasm-platform-registry.localhost:5001/wp-operator'

def wp_operator(namespace):
    custom_build(
        IMAGE_REF,
        command = (
            'docker build' +
            ' -t $EXPECTED_REF' +
            ' components/wp-operator'
        ),
        deps = [
            'components/wp-operator/cmd',
            'components/wp-operator/api',
            'components/wp-operator/internal',
            'components/wp-operator/go.mod',
            'components/wp-operator/go.sum',
        ],
    )

    helm_resource(
        'wp-operator',
        chart = 'components/wp-operator/helm',
        image_deps = [IMAGE_REF],
        image_keys = [('image.repository', 'image.tag')],
        labels = ['platform'],
        namespace=namespace,
        port_forwards = ['50051:50051'],
        flags = [
            '--set=databases.postgresDatabaseName=wp-databases-postgres',
        ],
    )

    local_resource(
        'wp: unit-tests',
        cmd = 'cd components/wp-operator && go test ./...',
        deps = [
            'components/wp-operator/cmd',
            'components/wp-operator/api',
            'components/wp-operator/internal',
        ],
        labels = ['tests'],
        auto_init=False,
        trigger_mode = TRIGGER_MODE_MANUAL,
    )

    local_resource(
        'wp: integration-tests',
        cmd = 'cd components/wp-operator && go test -tags integration -v ./internal/integration/...',
        deps = [
            'components/wp-operator/internal/integration',
        ],
        resource_deps = ['wp-operator'],
        labels = ['tests'],
        auto_init=False,
        trigger_mode = TRIGGER_MODE_MANUAL,
    )
